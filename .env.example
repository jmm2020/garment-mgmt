DATABASE_URL=postgres://dev:dev@localhost:5432/garment_mgmt
TEST_DATABASE_URL=postgres://dev:dev@localhost:5432/garment_mgmt_test
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=development
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=dev

# Shopify Admin API (iteration 2+). Required scopes: write_inventory, read_inventory,
# read_products, read_locations, write_metafields. Leave blank to disable push job.
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_LOCATION_ID=gid://shopify/Location/00000000000
# SHOPIFY_PUSH_INTERVAL_MS=30000  # Push loop tick interval (ms). Default: 30 000 ms.

# InvenTree raw-materials API (iteration 2+). Leave blank to disable sync.
INVENTREE_BASE_URL=http://localhost:8000
INVENTREE_API_TOKEN=your-inventree-token
