{
  "name": "garment-mgmt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production Hub — apparel manufacturing data layer + services",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm -r test",
    "dev": "pnpm --filter @garment-mgmt/server dev",
    "migrate": "pnpm --filter @garment-mgmt/db migrate",
    "seed": "pnpm --filter @garment-mgmt/db seed",
    "generate": "pnpm --filter @garment-mgmt/db generate",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres && node -e \"setTimeout(()=>{},2000)\"",
    "cli": "pnpm --filter @garment-mgmt/cli start"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "eslint": "^9.10.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
